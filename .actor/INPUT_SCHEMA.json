{
  "title": "eBay Scraper Input",
  "description": "Configuration for eBay listing scraping",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "keywords": {
      "title": "Search Keywords",
      "type": "array",
      "description": "Keywords to search for on eBay",
      "items": { "type": "string" },
      "editor": "stringList"
    },
    "maxItems": {
      "title": "Maximum Items",
      "type": "integer",
      "description": "Maximum number of items to scrape",
      "default": 30,
      "minimum": 1,
      "maximum": 500
    },
    "condition": {
      "title": "Condition",
      "type": "string",
      "description": "Filter by item condition",
      "enum": ["New", "Used"],
      "default": "New"
    }
  },
  "required": ["keywords"]
}